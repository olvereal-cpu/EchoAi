{
  "crons": [
    {
      "path": "/api/telegram_bot",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/telegram_bot",
      "destination": "/api/telegram_bot.ts"
    },
    {
      "source": "/api/admin/stats",
      "destination": "/api/admin_stats.ts"
    },
    {
      "source": "/api/admin/webhook",
      "destination": "/api/admin_webhook.ts"
    },
    {
      "source": "/api/admin/webhook/delete",
      "destination": "/api/admin_webhook.ts"
    }
  ]
}
