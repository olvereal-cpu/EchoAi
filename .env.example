# GEMINI_API_KEY: Required for Gemini AI API calls.
# Use VITE_ prefix for client-side environments (Vercel)
VITE_GEMINI_API_KEY="YOUR_GEMINI_KEY"
GEMINI_API_KEY="YOUR_GEMINI_KEY"

# TELEGRAM_BOT_TOKEN: Required for the Telegram bot integration
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# ADMIN_ID: Your Telegram ID (get it from @userinfobot)
ADMIN_ID="YOUR_TELEGRAM_ID"

# CHANNEL_ID: The ID of the channel for mandatory subscription (e.g., -100123456789)
REQUIRED_CHANNEL_ID="YOUR_CHANNEL_ID"
CHANNEL_LINK="https://t.me/your_channel"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
